# /etc/sudoers.d/deploy-runner — узкий passwordless sudo для GH Actions runner.
# Юзер 'deploy' может только то, что нужно для деплоя GradeSentinel.
# Установка: sudo install -m 0440 -o root -g root deploy-sudoers /etc/sudoers.d/deploy-runner
# Проверка: sudo visudo -cf deploy-sudoers
#
# Принцип: каждая команда — точный путь и точные аргументы. Никаких wildcards
# в bin-путях, чтобы deploy не мог через sudo выполнить произвольный код.

# Запись секретов и кода (только в нужные директории)
deploy ALL=(root) NOPASSWD: /usr/bin/install -d -o gradesentinel -g gradesentinel -m 0750 /etc/gradesentinel
deploy ALL=(root) NOPASSWD: /usr/bin/install -d -o gradesentinel -g gradesentinel -m 0750 /opt/gradesentinel
deploy ALL=(root) NOPASSWD: /usr/bin/install -d -o gradesentinel -g gradesentinel -m 0750 /var/lib/gradesentinel

# Атомарная запись секретов через tee (deploy.yml пишет в эти файлы)
deploy ALL=(root) NOPASSWD: /usr/bin/tee /etc/gradesentinel/bot.env
deploy ALL=(root) NOPASSWD: /usr/bin/tee /etc/gradesentinel/credentials.json

# Права на секреты
deploy ALL=(root) NOPASSWD: /usr/bin/chmod 0640 /etc/gradesentinel/bot.env
deploy ALL=(root) NOPASSWD: /usr/bin/chmod 0640 /etc/gradesentinel/credentials.json
deploy ALL=(root) NOPASSWD: /usr/bin/chown root\:gradesentinel /etc/gradesentinel/bot.env
deploy ALL=(root) NOPASSWD: /usr/bin/chown root\:gradesentinel /etc/gradesentinel/credentials.json

# ── Атомарный деплой (B19): stage(.new) → swap → .old для отката ──────────
# Синхронизация кода в STAGING /opt/gradesentinel.new — exact match с deploy.yml.
# Source path жёстко зафиксирован структурой actions-runner _work/<repo>/<repo>.
# Destination-пути фиксированы (.new/.old/live) → нет privilege escalation.
deploy ALL=(root) NOPASSWD: /usr/bin/rm -rf /opt/gradesentinel.new
deploy ALL=(root) NOPASSWD: /usr/bin/rsync -a --delete --exclude=venv --exclude=.git --exclude=data --exclude=config --exclude=.github --exclude=tests /home/deploy/actions-runner/_work/GradeSentinel_bot/GradeSentinel_bot/ /opt/gradesentinel.new/
deploy ALL=(root) NOPASSWD: /usr/bin/chown -R gradesentinel\:gradesentinel /opt/gradesentinel.new

# Атомарный свап каталогов (rename в пределах одной ФС) + освобождение слота отката.
# Обе стороны свапа whitelisted, чтобы деплой мог и переключиться, и откатиться.
deploy ALL=(root) NOPASSWD: /usr/bin/rm -rf /opt/gradesentinel.old
deploy ALL=(root) NOPASSWD: /usr/bin/mv /opt/gradesentinel /opt/gradesentinel.old
deploy ALL=(root) NOPASSWD: /usr/bin/mv /opt/gradesentinel.new /opt/gradesentinel
# Откат: битый релиз → .new, прошлый (.old) → живой.
deploy ALL=(root) NOPASSWD: /usr/bin/mv /opt/gradesentinel /opt/gradesentinel.new
deploy ALL=(root) NOPASSWD: /usr/bin/mv /opt/gradesentinel.old /opt/gradesentinel

# Установка systemd-юнитов (после rsync они могли обновиться)
deploy ALL=(root) NOPASSWD: /usr/bin/install -m 0644 /opt/gradesentinel/deploy/gradesentinel-bot.service /etc/systemd/system/gradesentinel-bot.service
deploy ALL=(root) NOPASSWD: /usr/bin/install -m 0644 /opt/gradesentinel/deploy/gradesentinel-webapp.service /etc/systemd/system/gradesentinel-webapp.service
deploy ALL=(root) NOPASSWD: /usr/bin/install -m 0644 /opt/gradesentinel/deploy/gradesentinel-heartbeat.service /etc/systemd/system/gradesentinel-heartbeat.service
deploy ALL=(root) NOPASSWD: /usr/bin/install -m 0644 /opt/gradesentinel/deploy/gradesentinel-heartbeat.timer /etc/systemd/system/gradesentinel-heartbeat.timer
# Мультитенантный VPS: деплой пишет ТОЛЬКО свой фрагмент в conf.d (не мастер),
# чтобы не затирать чужие сайты (b2b.railtech.uz). Мастер создаёт install.sh.
deploy ALL=(root) NOPASSWD: /usr/bin/install -m 0644 /opt/gradesentinel/deploy/Caddyfile /etc/caddy/conf.d/grades.caddy

# Управление сервисами (только наши, по префиксу gradesentinel-)
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl restart gradesentinel-bot.service
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl restart gradesentinel-webapp.service
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl reload caddy.service
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl enable gradesentinel-bot.service
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl enable gradesentinel-webapp.service
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl enable gradesentinel-heartbeat.timer
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl is-active gradesentinel-bot.service
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl is-active gradesentinel-webapp.service

# Per-release venv в STAGING от юзера gradesentinel. Собираем свежий venv в
# .new, ставим строго из lock с проверкой хешей, затем smoke-компиляция —
# всё ДО атомарного свапа, живой релиз не трогается.
deploy ALL=(gradesentinel) NOPASSWD: /usr/bin/python3.12 -m venv /opt/gradesentinel.new/venv
deploy ALL=(gradesentinel) NOPASSWD: /opt/gradesentinel.new/venv/bin/pip install --upgrade pip
deploy ALL=(gradesentinel) NOPASSWD: /opt/gradesentinel.new/venv/bin/pip install --require-hashes -r /opt/gradesentinel.new/requirements.lock
deploy ALL=(gradesentinel) NOPASSWD: /opt/gradesentinel.new/venv/bin/python -m compileall -q /opt/gradesentinel.new/src /opt/gradesentinel.new/webapp

# Валидация Caddyfile до reload
deploy ALL=(root) NOPASSWD: /usr/bin/caddy validate --config /etc/caddy/Caddyfile

# ── Phase 1: Hugo лендинг — /var/www/gradesentinel-landing ─────────────────
# Целевая директория, синк собранной статики, owner www-data.
deploy ALL=(root) NOPASSWD: /usr/bin/install -d -o www-data -g www-data -m 0755 /var/www/gradesentinel-landing
deploy ALL=(root) NOPASSWD: /usr/bin/rsync -a --delete /home/deploy/actions-runner/_work/GradeSentinel_bot/GradeSentinel_bot/landing/public/ /var/www/gradesentinel-landing/
deploy ALL=(root) NOPASSWD: /usr/bin/chown -R www-data\:www-data /var/www/gradesentinel-landing
