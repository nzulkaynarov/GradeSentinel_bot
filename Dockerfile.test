# Тестовый образ: Python 3.12 + зависимости (миграция на PostgreSQL, 2026-06-29).
# Зависимости вшиты в образ → прогоны pytest без повторного pip install.
#   docker compose -f docker-compose.test.yml build tests
#   docker compose -f docker-compose.test.yml run --rm tests
FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
# Код монтируется томом в docker-compose.test.yml (.:/app); deps живут в site-packages.
