# Секретные ключи Google API
config/*.json

# Переменные окружения (Токены бота, пароли)
.env

# База данных (чтобы не затереть рабочую базу пустой версией из гита)
data/*.db
data/*.sqlite3
*.db
*.sqlite3
# SQLite WAL/SHM sidecars — появляются при работе бота локально через WAL mode
*.db-wal
*.db-shm
*.sqlite3-wal
*.sqlite3-shm

# Логи
logs/*.log

# Python cache
__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/

# Docker
.dockerignore

# OS файлы
.DS_Store
Thumbs.db

# Claude Code локальные настройки и временные файлы
.claude/settings.local.json
.claude/.session/
.claude/cache/

# Excel с реальными данными ребёнка — не должны быть в репо
*.xlsx

# --- Web rewrite (Phase 0+) ---
# Каждый подпроект имеет свой .gitignore (landing/, web/, api/),
# дублируем главные паттерны на верхнем уровне для надёжности.

# Hugo
landing/public/
landing/resources/_gen/
landing/.hugo_build.lock

# Next.js
web/node_modules/
web/.next/
web/out/
web/build/
web/.vercel
web/*.tsbuildinfo

# FastAPI
api/.venv/
api/.pytest_cache/
api/.ruff_cache/
api/.mypy_cache/
api/uv.lock
