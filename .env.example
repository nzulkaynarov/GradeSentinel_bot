BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Admin Telegram ID (Ваш личный Telegram ID для глобального доступа)
ADMIN_ID=123456789

# Admin Group ID (ID группы для обратной связи и вопросов от пользователей)
# Если начинается с "-", указывать с минусом (например, -100123456789)
ADMIN_GROUP_ID=-1000000000000

# Claude AI Analytics (optional — if not set, AI features are disabled)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Payment Providers (Click / Payme via Telegram Payments API)
# Get tokens from @BotFather -> Payments -> Connect provider
# You can configure one or both providers
CLICK_PROVIDER_TOKEN=
PAYME_PROVIDER_TOKEN=
# Legacy: if CLICK/PAYME tokens are not set, this one is used as fallback
PAYMENT_PROVIDER_TOKEN=

# Manual card transfer (optional — shows "Card transfer" button in subscription)
# User sees card number + holder name, transfers money, admin confirms
PAYMENT_CARD_NUMBER=
PAYMENT_CARD_HOLDER=

# WebApp Dashboard URL (optional — HTTPS required for Telegram Mini Apps)
# Example: https://gradesentinel.example.com
# For local dev with ngrok: https://xxxx.ngrok-free.app
WEBAPP_URL=

# WebApp server port (default: 8443)
WEBAPP_PORT=8443
